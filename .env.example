# Copy this file to `.env` and fill in real values for local development.
# On Railway, set these as environment variables in the project dashboard instead.

# Kit (ConvertKit) API key — get it at Kit dashboard → Settings → Developer
KIT_API_KEY=

# Kit form ID (the numeric form ID from https://app.kit.com/forms/{id}/subscriptions)
KIT_FORM_ID=9335347
